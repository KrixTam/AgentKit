name: demo-echo
version: "1.0.0"
description: "示例 Echo Agent"
entry: agenthub.demo_agent:create_agent
skills: []
input_schema:
  type: object
  properties:
    input:
      type: string
  required:
    - input
output_schema:
  type: object
  properties:
    final_output:
      type: string
requires_human_input: false
runner_config:
  max_turns: 10
  default_hub_port: 8008
# 可选：为已开启 ModelCosplay 能力的 Agent 设置默认模型伪装
# model_cosplay: "gpt-4o-mini"
tags:
  - demo
  - stable
